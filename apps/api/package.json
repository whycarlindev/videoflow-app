{
  "name": "@videoflow/api",
  "version": "0.0.1",
  "description": "VideoFlow backend API (NestJS + Clean Architecture + DDD)",
  "scripts": {
    "dev": "bun run --watch src/infra/main.ts",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "dotenv -e .env.test -- vitest run --config ./vitest.config.e2e.mts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.16.1",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuidv7": "^1.2.1",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@nestjs/testing": "^10.0.0",
    "@swc/core": "^1.15.33",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.16.1",
    "supertest": "^7.0.0",
    "typescript": "^5.0.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^1.0.0"
  }
}
